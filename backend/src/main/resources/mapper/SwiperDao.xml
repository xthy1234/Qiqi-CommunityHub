    <!-- 分页查询列表 -->
    <select id="selectListView" resultMap="swiperMap">
        SELECT
        s.id,
        s.title,
        s.image_url,
        s.link_url,
        s.sort,
        s.status,
        s.description,
        s.is_deleted,
        s.create_time,
        s.update_time
        FROM swiper s
        <where>
            1=1
            <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
                AND ${ew.sqlSegment}
            </if>
        </where>
    </select>

    <!-- 查询视图 -->
    <select id="selectView" resultMap="swiperViewMap">
        SELECT
        s.id,
        s.title,
        s.image_url,
        s.link_url,
        s.sort,
        s.status,
        s.description,
        s.create_time,
        s.update_time,
        CASE s.status
        WHEN 0 THEN '隐藏'
        WHEN 1 THEN '显示'
        ELSE '未知'
        END as status_description
        FROM swiper s
        <where>
            1=1
            <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
                AND ${ew.sqlSegment}
            </if>
        </where>
    </select>

    <!-- 查询所有启用的轮播图 -->
    <select id="selectAllEnabled" resultMap="swiperMap">
        SELECT
            s.id,
            s.title,
            s.image_url,
            s.link_url,
            s.sort,
            s.status,
            s.description,
            s.is_deleted,
            s.create_time,
            s.update_time
        FROM swiper s
        WHERE s.status = 1
          AND s.is_deleted = false
        ORDER BY s.sort ASC
    </select>

</mapper>