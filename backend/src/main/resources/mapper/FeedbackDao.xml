    <!-- 分页查询反馈列表视图 -->
    <select id="selectListView" resultMap="feedbackViewMap">
        SELECT
            f.id,
            f.user_account,
            f.user_name,
            f.content,
            f.feedback_time,
            f.reply_content,
            f.reply_time,
            f.status,
            f.create_time,
            f.update_time,
            CASE f.status
                WHEN 0 THEN '待处理'
                WHEN 1 THEN '已回复'
                WHEN 2 THEN '已关闭'
                ELSE '未知状态'
            END as status_description
        FROM feedback f
        <where>
            1=1
            <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
                AND ${ew.sqlSegment}
            </if>
        </where>
        ORDER BY f.create_time DESC
    </select>

    <!-- 查询单个反馈视图 -->
    <select id="selectView" resultMap="feedbackViewMap">
        SELECT
            f.id,
            f.user_account,
            f.user_name,
            f.content,
            f.feedback_time,
            f.reply_content,
            f.reply_time,
            f.status,
            f.create_time,
            f.update_time,
            CASE f.status
                WHEN 0 THEN '待处理'
                WHEN 1 THEN '已回复'
                WHEN 2 THEN '已关闭'
                ELSE '未知状态'
            END as status_description
        FROM feedback f
        <where>
            1=1
            <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
                AND ${ew.sqlSegment}
            </if>
        </where>
    </select>

    <!-- 统计不同状态的反馈数量 -->
    <select id="countByStatus" resultType="int">
        SELECT COUNT(*)
        FROM feedback
        WHERE status = #{status}
    </select>

    <!-- 批量更新反馈状态 -->
    <update id="updateStatusBatch">
        UPDATE feedback
        SET status = #{status}, update_time = NOW()
        WHERE id IN
        <foreach collection="feedbackIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

</mapper>
