        <result property="id" column="id"/>
        <result property="contentTitle" column="content_title"/>
        <result property="contentCategory" column="content_category"/>
        <result property="reportedUserAccount" column="reported_user_account"/>
        <result property="reportedNickName" column="reported_user_name"/>
        <result property="reportReason" column="report_reason"/>
        <result property="reportTime" column="report_time"/>
        <result property="reporterAccount" column="reporter_account"/>
        <result property="reporterId" column="reporter_id"/>
        <result property="replyContent" column="reply_content"/>
        <result property="reviewStatus" column="review_status"/>
        <result property="reviewerAccount" column="reviewer_account"/>
        <result property="reviewTime" column="review_time"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- 举报视图结果映射 -->
    <resultMap type="com.gcs.entity.view.ReportView" id="reportViewMap" extends="reportMap">
        <result property="reviewStatusDescription" column="review_status_description"/>
        <result property="reporterNickname" column="reporter_nickname"/>
        <result property="reportedUserNickname" column="reported_user_nickname"/>
    </resultMap>

