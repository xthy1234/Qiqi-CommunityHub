    <!-- 分页查询Token列表视图 -->
    <select id="selectListView" resultMap="tokenMap">
        SELECT
            id,
            user_id,
            account,
            role_id,
            access_token,
            expire_time,
            create_time,
            update_time,
            status,
            ip_address,
            device_info
        FROM token
        <where>
            1=1
            <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
                AND ${ew.sqlSegment}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <!-- 根据用户 ID 和角色查询 Token -->
    <select id="selectByUserIdAndRole" resultMap="tokenMap">
        SELECT
            id,
            user_id,
            account,
            role_id,
            access_token,
            expire_time,
            create_time,
            update_time,
            status,
            ip_address,
            device_info
        FROM token
        WHERE user_id = #{userId}
        AND role_id = #{roleId}
        AND status = 0
        AND expire_time > NOW()
        LIMIT 1
    </select>

    <!-- 根据访问令牌查询Token -->
    <select id="selectByAccessToken" resultMap="tokenMap">
        SELECT
            id,
            user_id,
            account,
            role_id,
            access_token,
            expire_time,
            create_time,
            update_time,
            status,
            ip_address,
            device_info
        FROM token
        WHERE access_token = #{accessToken}
        AND status = 0
        AND expire_time > NOW()
        LIMIT 1
    </select>

    <!-- 清理过期 Token -->
    <delete id="cleanExpiredTokens">
        DELETE FROM token
        WHERE expire_time &lt; NOW()
        OR status = 1
    </delete>

    <!-- 批量删除用户 Token -->
    <delete id="deleteByUserId">
        DELETE FROM token
        WHERE user_id = #{userId}
    </delete>

    <!-- 插入 Token（处理 inet 类型） -->
    <insert id="insert" parameterType="com.gcs.entity.Token" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO token (
            user_id,
            account,
            role_id,
            access_token,
            expire_time,
            create_time,
            update_time,
            status,
            is_deleted,
            ip_address,
            device_info
        ) VALUES (
            #{userId},
            #{account},
            #{roleId},
            #{accessToken},
            #{expireTime},
            NOW(),
            NOW(),
            #{status},
            #{isDeleted},
            (#{ipAddress})::inet,
            #{deviceInfo}
        )
    </insert>

    <!-- 更新 Token（处理 inet 类型） -->
    <update id="updateById" parameterType="com.gcs.entity.Token">
        UPDATE token
        <set>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="account != null">account = #{account},</if>
            <if test="roleId != null">role_id = #{roleId},</if>
            <if test="accessToken != null">access_token = #{accessToken},</if>
            <if test="expireTime != null">expire_time = #{expireTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="status != null">status = #{status},</if>
            <if test="isDeleted != null">is_deleted = #{isDeleted},</if>
            <if test="ipAddress != null">ip_address = (#{ipAddress})::inet,</if>
            <if test="deviceInfo != null">device_info = #{deviceInfo},</if>
        </set>
        WHERE id = #{id}
    </update>

</mapper>
