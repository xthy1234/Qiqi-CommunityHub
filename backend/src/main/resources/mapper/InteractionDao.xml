<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gcs.dao.InteractionDao">

    <!-- 通用查询映射结果 -->
    <resultMap id="baseResultMap" type="com.gcs.entity.Interaction">
        <id column="id" property="id" />
        <result column="content_id" property="contentId" />
        <result column="table_name" property="tableName" />
        <result column="action_type" property="actionType" />
        <result column="user_id" property="userId" />
        <result column="status" property="status" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <!-- 视图映射结果 -->
    <resultMap id="viewResultMap" type="com.gcs.entity.view.InteractionView">
        <id column="id" property="id" />
        <result column="content_id" property="contentId" />
        <result column="table_name" property="tableName" />
        <result column="action_type" property="actionType" />
        <result column="user_id" property="userId" />
        <result column="status" property="status" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <!-- 根据用户和內容查询 -->
    <select id="selectByUserAndContent" resultType="com.gcs.entity.Interaction">
        SELECT * FROM interaction
        WHERE user_id = #{userId}
          AND content_id = #{contentId}
          AND action_type = #{actionType,typeHandler=com.gcs.handler.InteractionActionTypeHandler,jdbcType=INTEGER}
          AND table_name = #{tableName,typeHandler=com.gcs.handler.ContentTypeHandler,jdbcType=VARCHAR}
          AND status = 0
          AND is_deleted = false
    </select>

    <!-- 根据用户和內容查询所有记录（包括已删除的） -->
    <select id="selectByUserAndContentList" resultType="com.gcs.entity.Interaction">
        SELECT * FROM interaction
        WHERE user_id = #{userId}
          AND content_id = #{contentId}
          AND action_type = #{actionType,typeHandler=com.gcs.handler.InteractionActionTypeHandler,jdbcType=INTEGER}
          AND table_name = #{tableName,typeHandler=com.gcs.handler.ContentTypeHandler,jdbcType=VARCHAR}
        ORDER BY create_time DESC
    </select>

    <!-- 统计用户操作数量 -->
    <select id="countByUser" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM interaction
        WHERE user_id = #{userId}
        AND status = 0
        AND is_deleted = false
        <if test="actionType != null and actionType != ''">
            AND action_type = #{actionType,typeHandler=com.gcs.handler.InteractionActionTypeHandler,jdbcType=INTEGER}
        </if>
    </select>

    <!-- 批量删除用户操作 -->
    <delete id="deleteBatchByUser" parameterType="java.util.List">
        DELETE FROM interaction
        WHERE user_id = #{userId}
        AND id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 查询列表视图 -->
    <select id="selectListView" resultMap="viewResultMap">
        SELECT * FROM interaction
        <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
            ${ew.sqlSegment}
        </if>
    </select>

    <!-- 查询单个视图 -->
    <select id="selectView" resultType="com.gcs.entity.view.InteractionView">
        SELECT * FROM interaction
        <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
            ${ew.sqlSegment}
        </if>
        LIMIT 1
    </select>

</mapper>
