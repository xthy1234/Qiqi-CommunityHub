    <!-- 分页查询用户列表视图 -->
    <select id="selectListView" resultMap="userViewMap">
        SELECT
            u.id,
            u.account,
            u.password,
            u.nickname,
            u.avatar,
            u.gender,
            u.phone,
            u.email,
            u.role_id,
            u.birthday,
            u.signature,
            u.status,
            u.create_time,
            u.update_time,
            u.last_login_time,
            u.last_login_ip,
            CASE u.gender
                WHEN 0 THEN '女'
                WHEN 1 THEN '男'
                ELSE '保密'
            END as gender_description,
            CASE u.status
                WHEN 0 THEN '禁用'
                WHEN 1 THEN '启用'
                ELSE '未知'
            END as status_description
        FROM users u
        <where>
            1=1

            <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
                AND ${ew.sqlSegment}
            </if>
        </where>
        ORDER BY u.create_time DESC
    </select>

    <!-- 查询单个用户视图 -->
    <select id="selectView" resultMap="userViewMap">
        SELECT
            u.id,
            u.account,
            u.password,
            u.nickname,
            u.avatar,
            u.gender,
            u.phone,
            u.email,
            u.role_id,
            u.birthday,
            u.signature,
            u.status,
            u.create_time,
            u.update_time,
            u.last_login_time,
            u.last_login_ip,
            CASE u.gender
                WHEN 0 THEN '女'
                WHEN 1 THEN '男'
                ELSE '保密'
            END as gender_description,
            CASE u.status
                WHEN 0 THEN '禁用'
                WHEN 1 THEN '启用'
                ELSE '未知'
            END as status_description
        FROM users u
        <where>
            1=1
            <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
                AND ${ew.sqlSegment}
            </if>
        </where>
    </select>

    <!-- 根据账号查询用户 -->
    <select id="selectByAccount" resultType="com.gcs.entity.User">
        SELECT
            id,
            account,
            password,
            nickname,
            avatar,
            gender,
            phone,
            email,
            role_id,
            birthday,
            signature,
            status,
            create_time,
            update_time,
            last_login_time,
            last_login_ip
        FROM users
        WHERE account = #{account}
    </select>

    <!-- 根据手机号查询用户 -->
    <select id="selectByPhone" resultType="com.gcs.entity.User">
        SELECT
            id,
            account,
            password,
            nickname,
            avatar,
            gender,
            phone,
            email,
            role_id,
            birthday,
            signature,
            status,
            create_time,
            update_time,
            last_login_time,
            last_login_ip
        FROM users
        WHERE phone = #{phone}
    </select>

    <!-- 根据邮箱查询用户 -->
    <select id="selectByEmail" resultType="com.gcs.entity.User">
        SELECT
            id,
            account,
            password,
            nickname,
            avatar,
            gender,
            phone,
            email,
            role_id,
            birthday,
            signature,
            status,
            create_time,
            update_time,
            last_login_time,
            last_login_ip
        FROM users
        WHERE email = #{email}
    </select>

    <!-- 统计用户数量 -->
    <select id="countUsers" resultType="int">
        SELECT COUNT(*)
        FROM users
        <where>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
    </select>

    <!-- 更新用户最后登录信息 -->
    <update id="updateLastLoginInfo">
        UPDATE users
        SET last_login_time = NOW(),
            last_login_ip = (#{lastLoginIp})::inet,
            update_time = NOW()
        WHERE id = #{userId}
    </update>

</mapper>
