    <!-- 分页查询菜单列表视图 -->
    <select id="selectListView" resultMap="menuViewMap">
        SELECT
            m.id,
            m.name,
            m.component,
            m.parent_id,
            m.icon,
            m.path,
            m.sort,
            m.status,
            m.create_time,
            m.update_time,
            m.remark,
            p.name as parent_menu_name,
            CASE m.status
                WHEN 0 THEN '禁用'
                WHEN 1 THEN '启用'
                ELSE '未知'
            END as status_description,
            CASE m.type
                WHEN 1 THEN '系统菜单'
                WHEN 2 THEN '业务菜单'
                WHEN 3 THEN '自定义菜单'
                ELSE '未知类型'
            END as menu_type_description
        FROM menu m
        LEFT JOIN menu p ON m.parent_id = p.id
        <where>
            1=1
            <if test="ew != null">
                <if test="ew.entity != null">
                    <if test="ew.entity.id != null">
                        AND m.id = #{ew.entity.id}
                    </if>
                    <if test="ew.entity.name != null and ew.entity.name != ''">
                        AND m.name LIKE CONCAT('%', #{ew.entity.name}, '%')
                    </if>
                    <if test="ew.entity.type != null">
                        AND m.type = #{ew.entity.type}
                    </if>
                    <if test="ew.entity.parentId != null">
                        AND m.parent_id = #{ew.entity.parentId}
                    </if>
                    <if test="ew.entity.icon != null and ew.entity.icon != ''">
                        AND m.icon = #{ew.entity.icon}
                    </if>
                    <if test="ew.entity.path != null and ew.entity.path != ''">
                        AND m.path = #{ew.entity.path}
                    </if>
                    <if test="ew.entity.sort != null">
                        AND m.sort = #{ew.entity.sort}
                    </if>
                    <if test="ew.entity.status != null">
                        AND m.status = #{ew.entity.status}
                    </if>
                    <if test="ew.entity.isDeleted != null">
                        AND m.is_deleted = #{ew.entity.isDeleted}
                    </if>
                </if>
            </if>
        </where>
        ORDER BY m.sort ASC, m.create_time DESC
    </select>

    <!-- 查询单个菜单视图 -->
    <select id="selectView" resultMap="menuViewMap">
        SELECT
            m.id,
            m.name,
            m.component,
            m.parent_id,
            m.icon,
            m.path,
            m.sort,
            m.status,
            m.create_time,
            m.update_time,
            m.remark,
            p.name as parent_menu_name,
            CASE m.status
                WHEN 0 THEN '禁用'
                WHEN 1 THEN '启用'
                ELSE '未知'
            END as status_description,
            CASE m.type
                WHEN 1 THEN '系统菜单'
                WHEN 2 THEN '业务菜单'
                WHEN 3 THEN '自定义菜单'
                ELSE '未知类型'
            END as menu_type_description
        FROM menu m
        LEFT JOIN menu p ON m.parent_id = p.id
        <where>
            1=1
            <if test="ew != null">
                <if test="ew.entity != null">
                    <if test="ew.entity.id != null">
                        AND m.id = #{ew.entity.id}
                    </if>
                </if>
            </if>
        </where>
    </select>

    <!-- 查询所有启用的菜单（树形结构） -->
    <select id="selectMenuTree" resultMap="menuViewMap">
        SELECT
            m.id,
            m.name,
            m.component,
            m.parent_id,
            m.icon,
            m.path,
            m.sort,
            m.status,
            m.create_time,
            m.update_time,
            m.remark,
            CASE m.status
                WHEN 0 THEN '禁用'
                WHEN 1 THEN '启用'
                ELSE '未知'
            END as status_description,
            CASE m.type
                WHEN 1 THEN '系统菜单'
                WHEN 2 THEN '业务菜单'
                WHEN 3 THEN '自定义菜单'
                ELSE '未知类型'
            END as menu_type_description
        FROM menu m
        WHERE m.status = 1
        ORDER BY m.parent_id ASC, m.sort ASC, m.create_time ASC
    </select>

    <!-- 根据父级 ID 查询子菜单 -->
    <select id="selectChildrenByParentId" resultMap="menuViewMap">
        SELECT
            m.id,
            m.name,
            m.component,
            m.parent_id,
            m.icon,
            m.path,
            m.sort,
            m.status,
            m.create_time,
            m.update_time,
            m.remark,
            CASE m.status
                WHEN 0 THEN '禁用'
                WHEN 1 THEN '启用'
                ELSE '未知'
            END as status_description,
            CASE m.type
                WHEN 1 THEN '系统菜单'
                WHEN 2 THEN '业务菜单'
                WHEN 3 THEN '自定义菜单'
                ELSE '未知类型'
            END as menu_type_description
        FROM menu m
        WHERE m.parent_id = #{parentId}
        AND m.status = 1
        ORDER BY m.sort ASC, m.create_time ASC
    </select>

    <!-- 统计菜单数量 -->
    <select id="countMenus" resultType="int">
        SELECT COUNT(*)
        FROM menu m
        <where>
            <if test="type != null">
                AND m.type = #{type}
            </if>
            <if test="status != null">
                AND m.status = #{status}
            </if>
        </where>
    </select>

    <!-- 根据角色 ID 查询菜单 ID 列表 -->
    <select id="selectMenuIdsByRoleIds" resultType="java.lang.Long">
        SELECT DISTINCT m.id
        FROM menu m
        INNER JOIN role_menu rm ON m.id = rm.menu_id
        WHERE rm.role_id IN
        <foreach collection="roleIds" item="roleId" open="(" separator="," close=")">
            #{roleId}
        </foreach>
        AND m.status = 1
        ORDER BY m.id ASC
    </select>

</mapper>
