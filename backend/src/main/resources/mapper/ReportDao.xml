    <!-- 分页查询举报列表视图 -->
    <select id="selectListView" resultMap="reportViewMap">
        SELECT
            r.id,
            r.content_title,
            r.content_category,
            r.reported_user_account,
            r.reported_user_name,
            r.report_reason,
            r.report_time,
            r.reporter_account,
            r.reporter_id,
            r.reply_content,
            r.review_status,
            r.reviewer_account,
            r.review_time,
            r.status,
            r.create_time,
            r.update_time,
            CASE r.review_status
                WHEN 0 THEN '待审核'
                WHEN 1 THEN '已通过'
                WHEN 2 THEN '已拒绝'
                ELSE '未知状态'
            END as review_status_description,
            ur.account as reporter_nickname,
            uu.account as reported_user_nickname
        FROM report r
        LEFT JOIN user ur ON r.reporter_id = ur.id
        LEFT JOIN user uu ON r.reported_user_account = uu.account
        <where>
            1=1
            <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
                AND ${ew.sqlSegment}
            </if>
        </where>
        ORDER BY r.create_time DESC
    </select>

    <!-- 查询单个举报视图 -->
    <select id="selectView" resultMap="reportViewMap">
        SELECT
            r.id,
            r.content_title,
            r.content_category,
            r.reported_user_account,
            r.reported_user_name,
            r.report_reason,
            r.report_time,
            r.reporter_account,
            r.reporter_id,
            r.reply_content,
            r.review_status,
            r.reviewer_account,
            r.review_time,
            r.status,
            r.create_time,
            r.update_time,
            CASE r.review_status
                WHEN 0 THEN '待审核'
                WHEN 1 THEN '已通过'
                WHEN 2 THEN '已拒绝'
                ELSE '未知状态'
            END as review_status_description,
            ur.account as reporter_nickname,
            uu.account as reported_user_nickname
        FROM report r
        LEFT JOIN users ur ON r.reporter_id = ur.id
        LEFT JOIN users uu ON r.reported_user_account = uu.account
        <where>
            1=1
            <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
                AND ${ew.sqlSegment}
            </if>
        </where>
    </select>

    <!-- 统计不同审核状态的举报数量 -->
    <select id="countByReviewStatus" resultType="int">
        SELECT COUNT(*)
        FROM report
        WHERE review_status = #{reviewStatus}
        AND status = 1
    </select>

    <!-- 批量更新举报审核状态 -->
    <update id="updateReviewStatusBatch">
        UPDATE report
        SET review_status = #{reviewStatus},
            reviewer_account = #{reviewerAccount},
            review_time = NOW(),
            update_time = NOW()
        WHERE id IN
        <foreach collection="reportIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

</mapper>
