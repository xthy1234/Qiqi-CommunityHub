    <!-- 分页查询分类列表视图 -->
    <select id="selectListView" resultType="com.gcs.entity.view.CategoryView">
        SELECT
            c.id,
            c.category_name as categoryName,
            c.description,
            c.sort,
            c.status,
            c.create_time as createTime,
            c.update_time as updateTime,
            (SELECT COUNT(*) FROM article a WHERE a.category_id = c.id AND a.deleted = false) as articleCount
        FROM category c
        <where>
            1=1
            <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
                AND ${ew.sqlSegment}
            </if>
        </where>
        ORDER BY c.sort ASC, c.create_time DESC
    </select>

    <!-- 查询单个分类视图 -->
    <select id="selectView" resultType="com.gcs.entity.view.CategoryView">
        SELECT
            c.id,
            c.category_name as categoryName,
            c.description,
            c.sort,
            c.status,
            c.create_time as createTime,
            c.update_time as updateTime,
            (SELECT COUNT(*) FROM article a WHERE a.category_id = c.id AND a.deleted = false) as articleCount
        FROM category c
        <where>
            1=1
            <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
                AND ${ew.sqlSegment}
            </if>
        </where>
    </select>

</mapper>
